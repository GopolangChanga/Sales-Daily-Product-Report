-- =============================================
-- usp_Load_dimcustomer
--
-- Bug fix: the original used "CASE AccountNumber WHEN NULL THEN ..."
-- which never actually fires -- "column = NULL" is always UNKNOWN in
-- SQL Server, never TRUE, so the NULL case silently fell through to
-- ELSE every time. Rewritten below using "IS NULL", which works.
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_dimcustomer
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE [dbo].[Customer_Dim];

        INSERT INTO Customer_Dim ([CustomerID], [PersonID], [StoreID], [TerritoryID], [AccountNumber], ModifiedDate_Customer)
        SELECT
            [CustomerID], [PersonID], [StoreID], [TerritoryID], [AccountNumber], ModifiedDate_Customer
        FROM
        (
            SELECT
                [CustomerID], [PersonID], [StoreID], [TerritoryID],

                CASE
                    WHEN [AccountNumber] IS NULL OR [AccountNumber] = '' THEN 'Unknown_Value'
                    ELSE [AccountNumber]
                END AS [AccountNumber],

                ModifiedDate AS ModifiedDate_Customer
            FROM [AdventureWorks_Stage].[dbo].[Customer_Stage]
        ) AS Customer;

        COMMIT TRANSACTION;
        SELECT @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_dimcustomer;


-- =============================================
-- usp_Load_dimcustomerdetail
--
-- DEPENDENCY: must run AFTER usp_Load_dimperson and usp_Load_dimcustomer,
-- since this reads from Person_Dim and Customer_Dim directly (not staging).
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_dimcustomerdetail
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE [dbo].[CustomerDetail_Dim];

        INSERT INTO CustomerDetail_Dim (
            [PersonID], [PersonType], [FirstName], [LastName], [EmailPromotion], [Person_ModifiedDate],
            [CustomerID], [StoreID], [TerritoryID], [AccountNumber], [ModifiedDate_Customer]
        )
        SELECT DISTINCT
            Person_Dim.[PersonID], Person_Dim.[PersonType], Person_Dim.[FirstName],
            Person_Dim.[LastName], Person_Dim.[EmailPromotion], Person_Dim.[Person_ModifiedDate],
            Customer_Dim.[CustomerID], Customer_Dim.[StoreID], Customer_Dim.[TerritoryID],
            Customer_Dim.[AccountNumber], Customer_Dim.[ModifiedDate_Customer]
        FROM
        (
            SELECT [PersonID], [PersonType], [FirstName], [LastName], [EmailPromotion], [Person_ModifiedDate]
            FROM [AdventureWorks_Presentation].[dbo].[Person_Dim]
        ) AS Person_Dim
        INNER JOIN
        (
            SELECT [CustomerID], [PersonID], [StoreID], [TerritoryID], [AccountNumber], [ModifiedDate_Customer]
            FROM [AdventureWorks_Presentation].[dbo].[Customer_Dim]
        ) AS Customer_Dim
            ON Person_Dim.[PersonID] = Customer_Dim.[PersonID];

        COMMIT TRANSACTION;
        SELECT @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_dimcustomerdetail;


