-- =============================================
-- Procedure:   usp_Load_dimproduct
-- Purpose:     Transforms raw Product_Stage data into Product_Dim,
--              the presentation-layer dimension table.
--
-- Notes:       - ProductID is used as the shared key across the model
--                (no surrogate key for now — Type 1, full reload only).
--              - 'Unknown_Value' is applied only to descriptive/label
--                fields where blank genuinely means "we don't know
--                this attribute" (ProductName, Class, Style, ProductLine).
--                It is NOT applied to Size (derived, null = not
--                applicable, not missing) or to date fields (null
--                carries real meaning: still active / not discontinued).
-- =============================================
USE AdventureWorks_Presentation;
GO
SET ANSI_NULLS ON;
GO
SET QUOTED_IDENTIFIER ON;
GO

CREATE OR ALTER PROCEDURE usp_Load_dimproduct
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE [dbo].[Product_Dim];

        INSERT INTO Product_Dim (
            [ProductID], [ProductSubcategoryID], [ProductModelID],
            [ProductName],
            [Size],
            [BaseProductName],
            [ProductNumber], [MakeFlag], [FinishedGoodsFlag],
            [ReorderPoint], [StandardCost], [ListPrice], [ProductLine], [Class], [Style],
            [SellStartDate], [SellEndDate],
            [DiscontinuedDate], [Product_ModifiedDate]
        )
        SELECT
            [ProductID], [ProductSubcategoryID], [ProductModelID],

            CASE
                WHEN [ProductName] IS NULL OR [ProductName] = '' THEN 'Unknown_Value'
                ELSE [ProductName]
            END AS [ProductName],

            [Size],

            CASE
                WHEN RTRIM([BaseProductName]) LIKE '%-' THEN LEFT(RTRIM([BaseProductName]), LEN(RTRIM([BaseProductName])) - 1)
                ELSE [BaseProductName]
            END AS [BaseProductName],

            [ProductNumber], [MakeFlag], [FinishedGoodsFlag],
            [ReorderPoint], [StandardCost], [ListPrice],

            CASE
                WHEN [ProductLine] IS NULL OR [ProductLine] = '' THEN 'Unknown_Value'
                ELSE [ProductLine]
            END AS [ProductLine],

            [Class], [Style],
            [SellStartDate], [SellEndDate],
            [DiscontinuedDate], [Product_ModifiedDate]
        FROM
        (
            SELECT
                [ProductID],

                [Name] AS [ProductName],

                -- Extract the size or number part
                CASE
                    -- Case 1: Text contains a comma, size comes after comma
                    WHEN [Name] LIKE '%,%' THEN
                        LTRIM(SUBSTRING([Name], CHARINDEX(',', [Name]) + 1, LEN([Name])))
                    -- Case 2: Ends with a space + number (e.g. "Washer 1", "Hex Nut 12")
                    WHEN [Name] LIKE '% [0-9]%' OR [Name] LIKE '% [0-9]' THEN
                        RIGHT([Name], CHARINDEX(' ', REVERSE([Name])) - 1)
                    -- Otherwise, no size info
                    ELSE NULL
                END AS Size,

                -- Extract the base product name
                CASE
                    -- Case 1: Has a comma before size
                    WHEN [Name] LIKE '%,%' THEN
                        RTRIM(SUBSTRING([Name], 1, CHARINDEX(',', [Name]) - 1))
                    -- Case 2: Ends with a number, remove last word
                    WHEN [Name] LIKE '% [0-9]%' OR [Name] LIKE '% [0-9]' THEN
                        LEFT([Name], LEN([Name]) - CHARINDEX(' ', REVERSE([Name])))
                    -- Otherwise, full name as is
                    ELSE [Name]
                END AS BaseProductName,

                [ProductNumber], [MakeFlag], [FinishedGoodsFlag],
                [ReorderPoint], [StandardCost], [ListPrice], [ProductLine],

                CASE
                    WHEN [Class] IS NULL OR [Class] = '' THEN 'Unknown_Value'
                    ELSE [Class]
                END AS [Class],

                CASE
                    WHEN [Style] IS NULL OR [Style] = '' THEN 'Unknown_Value'
                    ELSE [Style]
                END AS [Style],

                [ProductSubcategoryID], [ProductModelID], [SellStartDate], [SellEndDate],
                [DiscontinuedDate], ModifiedDate AS [Product_ModifiedDate]
            FROM [AdventureWorks_Stage].[dbo].[Product_Stage]
        ) AS Product_Stage;

        COMMIT TRANSACTION;

        SELECT @@ROWCOUNT AS RowsLoaded;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO

-- Running the proc
-- EXEC [dbo].[usp_Load_dimproduct];

-- =============================================
-- Dim layer load procedures for AdventureWorks_Presentation
--
-- Standard pattern applied throughout:
--   - TRUNCATE + full reload every run (Type 1, no history)
--   - Wrapped in TRY/CATCH + transaction so a failure never leaves
--     a Dim table empty with no error surfaced
--   - 'Unknown_Value' applied only to descriptive/label fields where
--     blank genuinely means "we don't know this attribute" -- not to
--     numeric fields, derived nulls, or dates where null is meaningful
--   - Dead/leftover commented-out dedup blocks removed (not needed;
--     TRUNCATE already guarantees no duplicates)
--
-- Run order matters for one of these:
--   usp_Load_dimperson and usp_Load_dimcustomer must both run BEFORE
--   usp_Load_dimcustomerdetail, since that proc reads from Person_Dim
--   and Customer_Dim directly, not from staging.
-- =============================================

USE AdventureWorks_Presentation;
GO
SET ANSI_NULLS ON;
GO
SET QUOTED_IDENTIFIER ON;
GO


-- =============================================
-- usp_Load_dimproductcategory
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_dimproductcategory
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE [dbo].[Productcategory_Dim];

        INSERT INTO Productcategory_Dim (
            [ProductCategoryID], [ProductCategory], ProductCategory_ModifiedDate
        )
        SELECT
            PC.[ProductCategoryID], PC.[ProductCategory], PC.ProductCategory_ModifiedDate
        FROM
        (
            SELECT
                [ProductCategoryID],
                [Name] AS [ProductCategory],
                [ModifiedDate] AS ProductCategory_ModifiedDate
            FROM [AdventureWorks_Stage].[dbo].[Productcategory_Stage]
        ) AS PC;

        COMMIT TRANSACTION;
        SELECT @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_dimproductcategory;


