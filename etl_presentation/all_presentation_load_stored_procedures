-- =============================================
-- usp_Load_dimperson
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_dimperson
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE [dbo].[Person_Dim];

        INSERT INTO Person_Dim (PersonID, PersonType, FirstName, LastName, EmailPromotion, Person_ModifiedDate)
        SELECT
            [PersonID], [PersonType], [FirstName], [LastName], [EmailPromotion], Person_ModifiedDate
        FROM
        (
            SELECT
                [BusinessEntityID] AS [PersonID],

                CASE
                    WHEN [PersonType] IS NULL OR [PersonType] = '' THEN 'Unknown_Value'
                    ELSE [PersonType]
                END AS [PersonType],

                CASE
                    WHEN [FirstName] IS NULL OR [FirstName] = '' THEN 'Unknown_Value'
                    ELSE [FirstName]
                END AS [FirstName],

                CASE
                    WHEN [LastName] IS NULL OR [LastName] = '' THEN 'Unknown_Value'
                    ELSE [LastName]
                END AS [LastName],

                -- Numeric field: 0 used as the "no promotion opted in" default,
                -- not 'Unknown_Value' (which is a string and wouldn't fit anyway)
                CASE
                    WHEN [EmailPromotion] IS NULL THEN 0
                    ELSE [EmailPromotion]
                END AS [EmailPromotion],

                ModifiedDate AS Person_ModifiedDate
            FROM [AdventureWorks_Stage].[dbo].[Person_Stage]
        ) AS Person;

        COMMIT TRANSACTION;
        SELECT @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_dimperson;


