-- =============================================
-- Fact table load procedures for AdventureWorks_Presentation
--
-- Incremental load by date range:
--   - @StartDate / @EndDate default to NULL, meaning "load everything"
--     if no parameters are passed.
--   - Uses a date-SCOPED DELETE (not TRUNCATE) before the insert, so
--     only the rows in the given window are cleared and reloaded --
--     everything outside that window stays untouched. This also
--     makes the proc safe to re-run for the same window without
--     creating duplicates.
--   - Do NOT reintroduce TRUNCATE here if parameters are in play --
--     TRUNCATE + a date filter wipes the whole table but only
--     reloads a slice of it, silently losing history. That's the
--     bug this DELETE-scoped pattern avoids.
-- =============================================

USE AdventureWorks_Presentation;
GO
SET ANSI_NULLS ON;
GO
SET QUOTED_IDENTIFIER ON;
GO


-- =============================================
-- usp_Load_factsalesorderdetail
--
-- BUG FIX: the original INSERT column list and SELECT column list
-- had [OrderQty] and [SpecialOfferID] in swapped positions relative
-- to each other. SQL Server matches columns positionally, not by
-- name, so this was silently writing OrderQty values into the
-- SpecialOfferID column and vice versa. Fixed below -- both lists
-- now use the exact same column order.
--
-- CarrierTrackingNumber intentionally excluded from the fact table
-- (kept as a comment, matching the original intent).
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_factsalesorderdetail
(
    @StartDate datetime = NULL,
    @EndDate   datetime = NULL
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        -- Clear only the rows in this window, so re-runs don't duplicate
        -- and data outside the window is left untouched
        DELETE FROM SalesOrderDetail_Fact
        WHERE (@StartDate IS NULL OR [SalesOrderDetail_ModifiedDate] >= @StartDate)
          AND (@EndDate   IS NULL OR [SalesOrderDetail_ModifiedDate] <= @EndDate);

        INSERT INTO SalesOrderDetail_Fact (
            [SalesOrderID], [SalesOrderDetailID], [ProductID], [SpecialOfferID],
            [OrderQty], [UnitPrice], [UnitPriceDiscount], [LineTotal], [SalesOrderDetail_ModifiedDate]
            -- [CarrierTrackingNumber] intentionally excluded
        )
        SELECT
            [SalesOrderID], [SalesOrderDetailID], [ProductID], [SpecialOfferID],
            [OrderQty], [UnitPrice], [UnitPriceDiscount], [LineTotal], [SalesOrderDetail_ModifiedDate]
        FROM
        (
            SELECT
                [SalesOrderID], [SalesOrderDetailID], [CarrierTrackingNumber], [OrderQty], [ProductID],
                [SpecialOfferID], [UnitPrice], [UnitPriceDiscount], [LineTotal],
                ModifiedDate AS [SalesOrderDetail_ModifiedDate]
            FROM [AdventureWorks_Stage].[dbo].[SalesOrderDetail_Stage]
        ) AS SalesOrderDetail
        WHERE (@StartDate IS NULL OR SalesOrderDetail.[SalesOrderDetail_ModifiedDate] >= @StartDate)
          AND (@EndDate   IS NULL OR SalesOrderDetail.[SalesOrderDetail_ModifiedDate] <= @EndDate);

        COMMIT TRANSACTION;
        SELECT @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_factsalesorderdetail;                                          -- full load
-- EXEC dbo.usp_Load_factsalesorderdetail @StartDate = '2013-06-30', @EndDate = '2014-07-31'; -- windowed load


-- =============================================
-- usp_Load_factsalesorderheader
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_factsalesorderheader
(
    @StartDate datetime = NULL,
    @EndDate   datetime = NULL
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        DELETE FROM SalesOrderHeader_Fact
        WHERE (@StartDate IS NULL OR [SalesOrderHeader_ModifiedDate] >= @StartDate)
          AND (@EndDate   IS NULL OR [SalesOrderHeader_ModifiedDate] <= @EndDate);

        INSERT INTO SalesOrderHeader_Fact (
            [SalesOrderID], [CustomerID], [SalesPersonID], [TerritoryID],
            [BillToAddressID], [ShipToAddressID], [ShipMethodID], [CreditCardID],
            [CurrencyRateID], [RevisionNumber], [OrderDate], [DueDate], [ShipDate],
            [Status], [OnlineOrderFlag], [SalesOrderNumber], [PurchaseOrderNumber],
            [AccountNumber], [CreditCardApprovalCode], [SubTotal], [TaxAmt],
            [Freight], [TotalDue], [SalesOrderHeader_ModifiedDate]
        )
        SELECT
            [SalesOrderID], [CustomerID], [SalesPersonID], [TerritoryID],
            [BillToAddressID], [ShipToAddressID], [ShipMethodID], [CreditCardID],
            [CurrencyRateID], [RevisionNumber], [OrderDate], [DueDate], [ShipDate],
            [Status], [OnlineOrderFlag], [SalesOrderNumber], [PurchaseOrderNumber],
            [AccountNumber], [CreditCardApprovalCode], [SubTotal], [TaxAmt],
            [Freight], [TotalDue], [SalesOrderHeader_ModifiedDate]
        FROM
        (
            SELECT
                [SalesOrderID], [CustomerID], [SalesPersonID], [TerritoryID],
                [BillToAddressID], [ShipToAddressID], [ShipMethodID], [CreditCardID],
                [CurrencyRateID], [RevisionNumber], [OrderDate], [DueDate], [ShipDate],
                [Status], [OnlineOrderFlag], [SalesOrderNumber], [PurchaseOrderNumber],
                [AccountNumber], [CreditCardApprovalCode], [SubTotal], [TaxAmt],
                [Freight], [TotalDue],
                ModifiedDate AS [SalesOrderHeader_ModifiedDate]
            FROM [AdventureWorks_Stage].[dbo].[SalesOrderHeader_Stage]
        ) AS SalesOrderHeader
        WHERE (@StartDate IS NULL OR SalesOrderHeader.[SalesOrderHeader_ModifiedDate] >= @StartDate)
          AND (@EndDate   IS NULL OR SalesOrderHeader.[SalesOrderHeader_ModifiedDate] <= @EndDate);

        COMMIT TRANSACTION;
        SELECT @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_factsalesorderheader;                                          -- full load
