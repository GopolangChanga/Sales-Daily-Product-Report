-- =============================================
-- Updated staging load procedures for AdventureWorks_Stage
--
-- Standard pattern applied to every proc below:
--   - Full raw copy from source, no filtering (business rules belong
--     downstream in the Dim load, not here)
--   - TRUNCATE + INSERT every run (staging is disposable / always fresh)
--   - BatchID   : unique ID per run, stamped on every row loaded
--   - LoadDateTime : when the row landed in staging
--   - Wrapped in a transaction with TRY/CATCH so a failure never
--     leaves the staging table half-loaded, and the error still
--     surfaces (important once these run inside SQL Agent Jobs)
--   - Final SELECT returns BatchID + row count so the caller/job
--     log can confirm what the run actually did
--
-- Run 01_alter_stage_tables_add_batch_columns.sql first.
-- =============================================

USE AdventureWorks_Stage;
GO
SET ANSI_NULLS ON;
GO
SET QUOTED_IDENTIFIER ON;
GO


-- =============================================
-- usp_Load_StagingSalesOrderHeader
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_StagingSalesOrderHeader
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @BatchID UNIQUEIDENTIFIER = NEWID();

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE dbo.SalesOrderHeader_Stage;

        INSERT INTO SalesOrderHeader_Stage (
            [SalesOrderID], [RevisionNumber], [OrderDate], [DueDate], [ShipDate],
            [Status], [OnlineOrderFlag], [SalesOrderNumber], [PurchaseOrderNumber],
            [AccountNumber], [CustomerID], [SalesPersonID], [TerritoryID],
            [BillToAddressID], [ShipToAddressID], [ShipMethodID], [CreditCardID],
            [CreditCardApprovalCode], [CurrencyRateID], [SubTotal], [TaxAmt],
            [Freight], [TotalDue], [Comment], [rowguid], [ModifiedDate],
            [BatchID], [LoadDateTime]
        )
        SELECT
            [SalesOrderID], [RevisionNumber], [OrderDate], [DueDate], [ShipDate],
            [Status], [OnlineOrderFlag], [SalesOrderNumber], [PurchaseOrderNumber],
            [AccountNumber], [CustomerID], [SalesPersonID], [TerritoryID],
            [BillToAddressID], [ShipToAddressID], [ShipMethodID], [CreditCardID],
            [CreditCardApprovalCode], [CurrencyRateID], [SubTotal], [TaxAmt],
            [Freight], [TotalDue], [Comment], [rowguid], [ModifiedDate],
            @BatchID, GETDATE()
        FROM [AdventureWorks2022].[Sales].[SalesOrderHeader];

        COMMIT TRANSACTION;
        SELECT @BatchID AS BatchID, @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_StagingSalesOrderHeader;


