-- =============================================
-- usp_Load_geography
-- Note: this one is derived from a join across StateProvince, Address,
-- and SalesTerritory, rather than a straight 1:1 source table copy.
-- Kept the "WHERE SpatialLocation IS NOT NULL" filter as-is since it's
-- a data-quality guard (can't geocode a row with no coordinates), not
-- a business rule — that distinction is worth keeping in mind, but
-- this one is fine to leave here.
-- =============================================
CREATE OR ALTER PROCEDURE usp_Load_geography
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @BatchID UNIQUEIDENTIFIER = NEWID();

    BEGIN TRY
        BEGIN TRANSACTION;

        TRUNCATE TABLE dbo.Geography_Stage;

        INSERT INTO Geography_Stage (
            [TerritoryID], Territory, [CountryRegionCode], [Group], Province,
            [City], Latitude, Longitude,
            BatchID, LoadDateTime
        )
        SELECT
            SP_A_ST.[TerritoryID], SP_A_ST.Territory, SP_A_ST.[CountryRegionCode],
            SP_A_ST.[Group], SP_A_ST.Province, SP_A_ST.[City],
            SP_A_ST.Latitude, SP_A_ST.Longitude,
            @BatchID, GETDATE()
        FROM (
            SELECT DISTINCT
                ST.[TerritoryID],
                ST.[Name] AS Territory,
                ST.[CountryRegionCode],
                ST.[Group],
                SP.[Name] AS Province,
                A.[City],
                A.[SpatialLocation].Lat  AS Latitude,
                A.[SpatialLocation].Long AS Longitude
            FROM [AdventureWorks2022].[Person].[StateProvince] AS SP
            INNER JOIN [AdventureWorks2022].[Person].[Address] AS A
                ON SP.[StateProvinceID] = A.[StateProvinceID]
            INNER JOIN [AdventureWorks2022].[Sales].[SalesTerritory] AS ST
                ON SP.[TerritoryID] = ST.[TerritoryID]
            -- Filters out addresses with no coordinates to geocode; data quality
            -- guard, not a business rule, so this stays here in staging
            WHERE A.[SpatialLocation] IS NOT NULL
        ) AS SP_A_ST;

        COMMIT TRANSACTION;
        SELECT @BatchID AS BatchID, @@ROWCOUNT AS RowsLoaded;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO
-- EXEC dbo.usp_Load_geography;


