-- =============================================
-- Adds BatchID + LoadDateTime tracking columns to every staging table
-- BatchID   : ties every row to the specific proc run that loaded it
-- LoadDateTime : when the row landed in staging (not the source's ModifiedDate)
-- Run this once against AdventureWorks_Stage before running the updated procs
-- =============================================

USE AdventureWorks_Stage;
GO

ALTER TABLE dbo.Product_Stage ADD
    BatchID      UNIQUEIDENTIFIER NOT NULL DEFAULT NEWID(),
    LoadDateTime DATETIME         NOT NULL DEFAULT GETDATE();
GO

